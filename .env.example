# Anthropic API
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Snowflake (same account as cdc-places-pipeline)
# Account format: <org>-<account> (find in Snowflake UI under Admin -> Accounts)
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_DATABASE=CDC_PLACES
SNOWFLAKE_WAREHOUSE=
SNOWFLAKE_ROLE=

# SQLite cache path (caches LLM responses to reduce API calls during development)
CACHE_DB_PATH=cache.sqlite
